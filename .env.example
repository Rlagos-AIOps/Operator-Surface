# =========================================================
# Operator Surface — environment variables
#
# Copy to .env.local and fill in the values. .env.local is
# gitignored. The values below are placeholders, not secrets.
#
# Source of truth for the hosted Supabase project:
#   https://supabase.com/dashboard/project/<project-ref>/settings/api
# =========================================================

# Hosted Supabase project URL.
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) API key. Safe to embed in the browser bundle —
# RLS policies enforce row-level access on top of this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# DO NOT add SUPABASE_SERVICE_ROLE_KEY here. It bypasses RLS and
# must live in the Hermes (agents) repo only — never in Operator
# Surface. Any code in this repo that needs elevated access is
# a mistake.
