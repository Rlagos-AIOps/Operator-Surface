# =========================================================
# Operator Surface — environment variables
#
# Copy to .env.local and fill in the values. .env.local is
# gitignored. The values below are placeholders, not secrets.
#
# Source of truth for the hosted Supabase project:
#   https://supabase.com/dashboard/project/<project-ref>/settings/api
# =========================================================

# Hosted Supabase project URL.
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) API key. Safe to embed in the browser bundle —
# RLS policies enforce row-level access on top of this key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# =========================================================
# SERVER-ONLY env vars below this line.
# Never prefix with NEXT_PUBLIC_ — these must NOT reach the browser.
# In Vercel, set the environment to "Server-side only" (default).
# =========================================================

# Service role JWT. Bypasses Row Level Security. Required by:
#   - scripts/seed.ts (dev seed)
#   - scripts/verify-seed.ts (row-count check)
#   - src/lib/supabase/admin.ts (server-only admin client)
#
# admin.ts is the DEMO-MODE workaround until Task 3 (Auth) lands.
# When real Auth wires up, admin.ts gets deleted and all reads
# return to the user-scoped client in src/lib/supabase/server.ts.
#
# Get the key from: Supabase dashboard → Settings → API → service_role.
# Rotate it from the same screen whenever it might have leaked.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Email of the seeded operator whose UUID is used as `decided_by`
# in approval writes from the demo UI. Must match a row in
# auth.users (seeded by scripts/seed.ts).
DEMO_OPERATOR_EMAIL=taylor@example-csm.test
