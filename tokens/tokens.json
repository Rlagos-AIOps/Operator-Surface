{
  "$description": "Ops Surfer (AI Ops OS) design tokens — DTCG. CANONICAL source of truth, mirrors operator-app/app/globals.css as shipped. Dual-theme: light = Figma emerald+paper, dark = Lovable mossy. Import primitives once, map color.light / color.dark to Figma Variable modes + Supernova themes. Grammar: color = signal (never decoration), always paired with a text/label cue; text is one color, elements get colored.",
  "primitive": {
    "emerald": { "$type": "color", "$value": "#1E5631", "$description": "Light canvas base" },
    "emerald-deep": { "$type": "color", "$value": "#163F23", "$description": "Deep recess / inset" },
    "mossy": { "$type": "color", "$value": "#0F2A26", "$description": "Dark canvas base" },
    "moss-surface": { "$type": "color", "$value": "#143832", "$description": "Dark elevated moss" },
    "paper": { "$type": "color", "$value": "#F4F1E8", "$description": "Cream two-tone film — speech bubbles" },
    "paper-2": { "$type": "color", "$value": "#EFEADB", "$description": "Slightly darker paper" },
    "ink": { "$type": "color", "$value": "#0A1410", "$description": "Dark text on light / lime / paper" },
    "bone": { "$type": "color", "$value": "#FDFDFA", "$description": "Bright off-white text on dark (no halation)" }
  },
  "color": {
    "light": {
      "background": { "$type": "color", "$value": "#1E5631", "$description": "Page canvas" },
      "foreground": { "$type": "color", "$value": "#F4F1E8", "$description": "Primary text" },
      "muted-foreground": { "$type": "color", "$value": "#E9E5D5", "$description": "Secondary text (solid — translucent washes out on emerald)" },
      "card": { "$type": "color", "$value": "#F2F2E614", "$description": "Panel — translucent cream film" },
      "surface": { "$type": "color", "$value": "#EBEBEB0D" },
      "surface-2": { "$type": "color", "$value": "#F5F5EB1A", "$description": "Hover / 2nd elevation" },
      "surface-edge": { "$type": "color", "$value": "#F3F3E629", "$description": "Hairline on panels" },
      "border": { "$type": "color", "$value": "#F1F1EA24" },
      "border-strong": { "$type": "color", "$value": "#F3EFE952", "$description": "Dashed / strong hairline" },
      "good": { "$type": "color", "$value": "#C7ED55", "$description": "active · success · running · shipped · the ONLY primary-action color (= primary)" },
      "good-foreground": { "$type": "color", "$value": "#0A1410", "$description": "Text on lime" },
      "hot": { "$type": "color", "$value": "#F57323", "$description": "hot lead · urgent" },
      "warm": { "$type": "color", "$value": "#F2C60E", "$description": "warm lead · caution" },
      "cold": { "$type": "color", "$value": "#3799E2", "$description": "cold lead · info" },
      "bad": { "$type": "color", "$value": "#E63946", "$description": "error · blocked · destructive (= destructive)" },
      "pending": { "$type": "color", "$value": "#B5C0C5", "$description": "queued · draft · in-review — luminous gray, NOT disabled" }
    },
    "dark": {
      "background": { "$type": "color", "$value": "#0A1F17" },
      "foreground": { "$type": "color", "$value": "#FDFDFA" },
      "muted-foreground": { "$type": "color", "$value": "#FDFDFAD9", "$description": "Secondary text — 0.85 alpha" },
      "card": { "$type": "color", "$value": "#EBEBEB0D" },
      "surface": { "$type": "color", "$value": "#FFFFDF08" },
      "surface-2": { "$type": "color", "$value": "#EEEEDD0F" },
      "surface-edge": { "$type": "color", "$value": "#1D3D30", "$description": "Present green edge" },
      "border": { "$type": "color", "$value": "#1F3F32", "$description": "Visible mossy hairline" },
      "border-strong": { "$type": "color", "$value": "#4A6D51" },
      "good": { "$type": "color", "$value": "#B9F719", "$description": "Lime at full chroma (= primary)" },
      "good-foreground": { "$type": "color", "$value": "#0A1410" },
      "hot": { "$type": "color", "$value": "#FC7A2C" },
      "warm": { "$type": "color", "$value": "#FFD32E" },
      "cold": { "$type": "color", "$value": "#3F9FE8" },
      "bad": { "$type": "color", "$value": "#EA3C3F" },
      "pending": { "$type": "color", "$value": "#C5D0D5" }
    }
  },
  "fontFamily": {
    "display": { "$type": "fontFamily", "$value": ["DM Serif Display", "Times New Roman", "serif"], "$description": "Money + headlines (h1/h2)" },
    "sans": { "$type": "fontFamily", "$value": ["Manrope", "Inter", "system-ui", "sans-serif"], "$description": "Body / UI" },
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"], "$description": "Ops / metadata / eyebrows / numerals" }
  },
  "fontSize": {
    "display": { "$type": "dimension", "$value": "56px" },
    "h1": { "$type": "dimension", "$value": "48px" },
    "h2": { "$type": "dimension", "$value": "40px" },
    "h3": { "$type": "dimension", "$value": "28px" },
    "h4": { "$type": "dimension", "$value": "20px" },
    "body": { "$type": "dimension", "$value": "16px", "$description": "Primary reading prose (text-base) — a11y floor for reading" },
    "small": { "$type": "dimension", "$value": "14px", "$description": "Dense UI / controls / metadata" },
    "eyebrow": { "$type": "dimension", "$value": "11px", "$description": "Uppercase mono labels — min for short labels" },
    "kbd": { "$type": "dimension", "$value": "10px", "$description": "Absolute min font size" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px", "$description": "Chips, tags" },
    "md": { "$type": "dimension", "$value": "8px", "$description": "Inputs" },
    "lg": { "$type": "dimension", "$value": "14px", "$description": "Standard cards" },
    "xl": { "$type": "dimension", "$value": "20px", "$description": "Hero cards" },
    "2xl": { "$type": "dimension", "$value": "28px", "$description": "PANEL" },
    "pill": { "$type": "dimension", "$value": "9999px", "$description": "Pills, avatars, buttons" }
  },
  "radiusBlade": {
    "$description": "Leaf-blade asymmetric radii — the signature chat-bubble shape",
    "human": { "$type": "dimension", "$value": "60px 15px 60px 15px" },
    "agent": { "$type": "dimension", "$value": "15px 60px 15px 60px" }
  },
  "shadow": {
    "1": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "1px", "color": "#F2F4E514" }, "$description": "Resting hairline weight" },
    "2": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "8px", "blur": "24px", "spread": "0", "color": "#00000066" }, "$description": "Raised" },
    "3": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "24px", "blur": "56px", "spread": "0", "color": "#0000008c" }, "$description": "Heavy elevation (pricing hover)" }
  }
}
