{
  "$description": "AI Ops OS design tokens — DTCG format. Source of truth mirrors app/globals.css @theme and lib/tokens.ts. Import this into Supernova as the design-system canon; it also exports to CSS/JSON/Swift/Kotlin from there.",
  "color": {
    "emerald": { "$type": "color", "$value": "#1E5631", "$description": "Primary canvas — always the dominant background" },
    "emerald-deep": { "$type": "color", "$value": "#163F23", "$description": "Sidebar, inset wells, deep recesses" },
    "surface": { "$type": "color", "$value": "#245F37", "$description": "Elevated card background" },
    "surface-2": { "$type": "color", "$value": "#2B6E40", "$description": "Hover / second elevation" },
    "surface-edge": { "$type": "color", "$value": "#3A8052", "$description": "Hairline divider on dark" },
    "paper": { "$type": "color", "$value": "#F4F1E8", "$description": "Cream surface — speech bubbles, ROI card" },
    "paper-2": { "$type": "color", "$value": "#ECE7D6", "$description": "Slightly darker paper" },
    "paper-edge": { "$type": "color", "$value": "#D8D2BE", "$description": "Border on paper surfaces" },
    "lime": { "$type": "color", "$value": "#D9E879", "$description": "The ONLY CTA color — every primary action" },
    "volt": { "$type": "color", "$value": "#C8F902", "$description": "Agent-active ONLY — pulse, live, fresh result" },
    "lime-deep": { "$type": "color", "$value": "#B8C95F", "$description": "Pressed lime" },
    "ink": { "$type": "color", "$value": "#0A1410", "$description": "Text on light / lime / paper" },
    "ink-2": { "$type": "color", "$value": "#1F2A24", "$description": "Secondary text on light" },
    "muted-foreground": { "$type": "color", "$value": "#8FA89A", "$description": "Muted text on dark" },
    "muted-paper": { "$type": "color", "$value": "#5A6E62", "$description": "Muted text on paper" },
    "success": { "$type": "color", "$value": "#D9E879", "$description": "Success" },
    "warning": { "$type": "color", "$value": "#E8A91C", "$description": "Warning" },
    "danger": { "$type": "color", "$value": "#D9402B", "$description": "Danger / destructive" },
    "info": { "$type": "color", "$value": "#6FB4D9", "$description": "Info" }
  },
  "fontFamily": {
    "serif": { "$type": "fontFamily", "$value": ["DM Serif Display", "Times New Roman", "serif"], "$description": "Display + numerals" },
    "sans": { "$type": "fontFamily", "$value": ["Manrope", "Inter", "system-ui", "sans-serif"], "$description": "UI / body" },
    "mono": { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"], "$description": "Code, telemetry" }
  },
  "fontSize": {
    "display": { "$type": "dimension", "$value": "56px" },
    "h2": { "$type": "dimension", "$value": "40px" },
    "h3": { "$type": "dimension", "$value": "28px" },
    "h4": { "$type": "dimension", "$value": "20px" },
    "body": { "$type": "dimension", "$value": "16px" },
    "small": { "$type": "dimension", "$value": "14px" },
    "eyebrow": { "$type": "dimension", "$value": "11px" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px", "$description": "Chips, tags" },
    "md": { "$type": "dimension", "$value": "8px", "$description": "Inputs, buttons" },
    "lg": { "$type": "dimension", "$value": "14px", "$description": "Standard cards" },
    "xl": { "$type": "dimension", "$value": "20px", "$description": "Hero cards, modals" },
    "pill": { "$type": "dimension", "$value": "9999px", "$description": "Pills, avatars" }
  },
  "shadow": {
    "ground": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "1px", "blur": "0", "spread": "0", "color": "#0A141433" }, "$description": "Ground level — most cards" },
    "glow-volt": { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "0", "blur": "24px", "spread": "4px", "color": "#C8F90273" }, "$description": "Agent-active halo — volt only" }
  }
}
